# Static Assets

GET     /assets/*file controllers.Assets.versioned(path="/public", file: Asset)

# Authentication

POST    /api/auth/register controllers.AuthController.register(request: Request)

POST    /api/auth/login controllers.AuthController.login(request: Request)

# Profile

GET     /api/profile controllers.ProfileController.profile(request: Request)

# Categories

POST    /api/categories controllers.CategoryController.create(request: Request)

GET     /api/categories controllers.CategoryController.getAll()

GET     /api/categories/:id controllers.CategoryController.getById(id: Long)

PUT     /api/categories/:id controllers.CategoryController.update(id: Long, request: Request)

DELETE  /api/categories/:id controllers.CategoryController.delete(id: Long)

# Products

GET     /api/products controllers.ProductController.getAll()

GET     /api/products/search controllers.ProductController.search(request: Request)

GET     /api/products/:id controllers.ProductController.getById(id: Long)

POST    /api/products controllers.ProductController.create(request: Request)

PUT     /api/products/:id controllers.ProductController.update(id: Long, request: Request)

DELETE  /api/products/:id controllers.ProductController.delete(id: Long, request: Request)

GET     /api/seller/products controllers.ProductController.sellerProducts(request: Request)

# Cart

POST    /api/cart/items controllers.CartController.addItem(request: Request)

GET     /api/cart controllers.CartController.viewCart(request: Request)

PUT     /api/cart/items/:cartItemId controllers.CartController.updateQuantity(cartItemId: Long, request: Request)

DELETE  /api/cart/items/:cartItemId controllers.CartController.removeItem(cartItemId: Long, request: Request)

# Orders

POST    /api/orders/checkout controllers.OrderController.checkout(request: Request)

GET     /api/orders/my-orders controllers.OrderController.myOrders(request: Request)

PUT     /api/orders/:orderId/cancel controllers.OrderController.cancelOrder(orderId: Long, request: Request)

GET     /api/seller/orders controllers.OrderController.sellerOrders(request: Request)

PUT     /api/seller/orders/:orderId/status controllers.OrderController.updateOrderStatus(orderId: Long, request: Request)

# Admin


GET    /api/admin/dashboard    controllers.AdminController.dashboard()
# Testing

GET     /api/test/admin controllers.TestController.adminApi()

GET     /api/test/seller controllers.TestController.sellerApi()

GET     /api/test/customer controllers.TestController.customerApi()